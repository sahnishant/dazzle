---
// src/components/ShopTheLook.astro
import { Image } from 'astro:assets';
import { jewelryItems } from '../data/jewelry.js';

interface Props {
  productIds: string[];
  title?: string;
  intro?: string;
}

const {
  productIds = [],
  title = 'Shop the Look',
  intro = 'Pieces selected to complement this guide and help you move from inspiration to inquiry.',
} = Astro.props;

const productsById = new Map(jewelryItems.map((item) => [item.id, item]));
const products = productIds
  .map((id) => productsById.get(id))
  .filter(Boolean);
---

{products.length > 0 && (
  <section class="shop-the-look" aria-labelledby="shop-the-look-title">
    <div class="shop-the-look-heading">
      <p class="shop-the-look-kicker">Editorial selection</p>
      <h2 id="shop-the-look-title">{title}</h2>
      <p>{intro}</p>
    </div>

    <div class="shop-the-look-grid">
      {products.map((product) => (
        <a class="shop-product-card" href={`/collections/${product.category}/${product.id}/`}>
          <Image
            src={product.mainImage}
            alt={product.name}
            width={700}
            height={560}
            format="webp"
            loading="lazy"
            decoding="async"
            class="shop-product-image"
          />
          <div class="shop-product-copy">
            <p class="shop-product-category">{product.category.replace(/-/g, ' ')}</p>
            <h3>{product.name}</h3>
            <p class="shop-product-price">{product.price}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .shop-the-look {
    margin-top: 3rem;
    padding: 2rem;
    border: 1px solid rgba(176, 160, 140, 0.28);
    border-radius: 14px;
    background: linear-gradient(135deg, #fffaf4 0%, #ffffff 100%);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .shop-the-look-heading {
    max-width: 760px;
    margin: 0 auto 1.5rem;
    text-align: center;
  }

  .shop-the-look-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .shop-the-look-heading h2 {
    margin: 0 0 0.6rem;
    color: #555;
    font-size: 2rem;
  }

  .shop-the-look-heading p:last-child {
    margin: 0;
    color: #666;
    line-height: 1.65;
  }

  .shop-the-look-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.25rem;
  }

  .shop-product-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 12px;
    background: #fff;
    color: #333;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.07);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .shop-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.1);
    text-decoration: none;
  }

  .shop-product-image {
    width: 100%;
    height: 210px;
    object-fit: cover;
  }

  .shop-product-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem;
  }

  .shop-product-category {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .shop-product-copy h3 {
    margin: 0 0 0.75rem;
    color: #555;
    font-size: 1.08rem;
    line-height: 1.35;
  }

  .shop-product-price {
    margin: auto 0 0;
    color: #B0A08C;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .shop-the-look {
      padding: 1.4rem;
    }
  }
</style>
