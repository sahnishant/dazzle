---
// src/components/FilterSidebar.astro
interface FilterOption {
  value: string;
  label: string;
  count: number;
}

interface Props {
  categories: FilterOption[];
  materials: FilterOption[];
  styles: FilterOption[];
}

const { categories, materials, styles } = Astro.props;
---

<aside class="filter-sidebar" aria-label="Collection filters">
  <div class="filter-header">
    <div>
      <p class="filter-kicker">Refine</p>
      <h2>Find your piece</h2>
      <p>Filter by form, metal, and design language.</p>
    </div>
    <button type="button" id="clearCollectionFilters" class="clear-filter-btn">Clear</button>
  </div>

  <fieldset class="filter-group">
    <legend>Category</legend>
    {categories.map((category) => (
      <label>
        <input type="checkbox" name="category" value={category.value} data-collection-filter="category" />
        <span>{category.label}</span>
        <small>{category.count}</small>
      </label>
    ))}
  </fieldset>

  <fieldset class="filter-group">
    <legend>Material</legend>
    {materials.map((material) => (
      <label>
        <input type="checkbox" name="material" value={material.value} data-collection-filter="material" />
        <span>{material.label}</span>
        <small>{material.count}</small>
      </label>
    ))}
  </fieldset>

  <fieldset class="filter-group">
    <legend>Style</legend>
    {styles.map((style) => (
      <label>
        <input type="checkbox" name="style" value={style.value} data-collection-filter="style" />
        <span>{style.label}</span>
        <small>{style.count}</small>
      </label>
    ))}
  </fieldset>
</aside>

<style>
  .filter-sidebar {
    position: sticky;
    top: 1rem;
    padding: 1.25rem;
    border: 1px solid rgba(176, 160, 140, 0.28);
    border-radius: 14px;
    background: #fffaf4;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .filter-header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .filter-kicker {
    margin: 0 0 0.25rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .filter-header h2 {
    margin: 0 0 0.3rem;
    color: #555;
    font-size: 1.3rem;
  }

  .filter-header p:last-child {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .clear-filter-btn {
    border: 1px solid rgba(176, 160, 140, 0.55);
    border-radius: 999px;
    background: #fff;
    color: #A0907C;
    cursor: pointer;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    padding: 0.35rem 0.8rem;
  }

  .clear-filter-btn:hover,
  .clear-filter-btn:focus-visible {
    background: #B0A08C;
    color: #fff;
  }

  .filter-group {
    border: 0;
    margin: 0 0 1.35rem;
    padding: 0;
  }

  .filter-group:last-child {
    margin-bottom: 0;
  }

  .filter-group legend {
    margin-bottom: 0.65rem;
    color: #555;
    font-weight: 700;
  }

  .filter-group label {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.55rem;
    color: #555;
    cursor: pointer;
    line-height: 1.35;
  }

  .filter-group input {
    accent-color: #B0A08C;
  }

  .filter-group small {
    display: inline-flex;
    min-width: 1.65rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(176, 160, 140, 0.16);
    color: #8a7663;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.65;
  }

  @media (max-width: 899px) {
    .filter-sidebar {
      position: static;
    }
  }
</style>
