---
import { trustPillars } from '../data/trustContent.js';
const { title = "Trust ledger before transaction", compact = false } = Astro.props;
---
<section class={`trust-ledger ${compact ? 'trust-ledger-compact' : ''}`} aria-labelledby="trust-ledger-title">
  <div class="trust-ledger-heading"><p>Trust system</p><h2 id="trust-ledger-title">{title}</h2></div>
  <div class="trust-ledger-grid">
    {trustPillars.map((pillar) => (<article><h3>{pillar.title}</h3><p>{pillar.body}</p></article>))}
  </div>
</section>
<style>
  .trust-ledger{margin:3rem 0;padding:2rem;border-radius:24px;background:linear-gradient(135deg,#2b2624,#463b34);color:#fffaf4}
  .trust-ledger-heading{max-width:820px;margin:0 auto 1.5rem;text-align:center}
  .trust-ledger-heading p{margin:0 0 .4rem;color:#f4dfbd;font-size:.78rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
  .trust-ledger-heading h2{margin:0;color:#fffaf4;font-size:clamp(1.8rem,4vw,3rem)}
  .trust-ledger-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1rem}
  .trust-ledger article{padding:1rem;border:1px solid rgba(244,223,189,.22);border-radius:18px;background:rgba(255,255,255,.06)}
  .trust-ledger h3{margin:0 0 .5rem;color:#f4dfbd;font-size:1.08rem}
  .trust-ledger p{margin:0;color:rgba(255,250,244,.82);line-height:1.65}
  .trust-ledger-compact{padding:1.5rem}
</style>
