---
import { merchantReadinessItems } from '../data/trustContent.js';
const { title = "Merchant Center readiness checklist" } = Astro.props;
---
<section class="merchant-trust-checklist" aria-labelledby="merchant-checklist-title">
  <p class="merchant-kicker">Google distribution</p>
  <h2 id="merchant-checklist-title">{title}</h2>
  <ul>{merchantReadinessItems.map((item) => <li>{item}</li>)}</ul>
</section>
<style>
  .merchant-trust-checklist{margin:2.5rem 0;padding:2rem;border-radius:22px;background:#f8f1e8;border:1px solid rgba(176,160,140,.32)}
  .merchant-kicker{margin:0 0 .35rem;color:#a0907c;font-size:.78rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
  .merchant-trust-checklist h2{margin:0 0 1rem;color:#3b332e}
  .merchant-trust-checklist ul{display:grid;gap:.75rem;list-style:none;margin:0;padding:0}
  .merchant-trust-checklist li{position:relative;padding-left:1.8rem;color:#5f544c;line-height:1.6}
  .merchant-trust-checklist li::before{content:"✓";position:absolute;left:0;color:#1f8f56;font-weight:900}
</style>
