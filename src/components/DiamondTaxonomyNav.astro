---
import { diamondTaxonomy } from '../data/diamondTaxonomy.js';
const { title = "Explore the Dazzle diamond tree", intro = "Move from laboratory-grown diamond to jewellery type, design family, and individual piece." } = Astro.props;
---
<section class="diamond-taxonomy-nav" aria-labelledby="diamond-taxonomy-title">
  <div class="taxonomy-heading">
    <p class="taxonomy-kicker">Catalogue architecture</p>
    <h2 id="diamond-taxonomy-title">{title}</h2>
    <p>{intro}</p>
  </div>
  <div class="taxonomy-root">
    <a href={diamondTaxonomy.root.href}>{diamondTaxonomy.root.label}</a>
    <span>{diamondTaxonomy.root.description}</span>
  </div>
  <div class="taxonomy-grid">
    {diamondTaxonomy.groups.map((group) => (
      <article class="taxonomy-card">
        <a class="taxonomy-card-title" href={group.href}>{group.label}</a>
        <p>{group.description}</p>
        <ul>
          {group.children.map((child) => (
            <li><a href={child.href}>{child.label}</a><span>{child.intent}</span></li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
<style>
  .diamond-taxonomy-nav{margin:3rem auto;padding:2rem;border:1px solid rgba(176,160,140,.28);border-radius:24px;background:#fffaf4}
  .taxonomy-heading{max-width:820px;margin:0 auto 1.5rem;text-align:center}
  .taxonomy-kicker{margin:0 0 .4rem;color:#a0907c;font-size:.78rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
  .taxonomy-heading h2{margin:0 0 .8rem;color:#3b332e;font-size:clamp(1.9rem,4vw,3rem)}
  .taxonomy-heading p{margin:0;color:#665b52;line-height:1.7}
  .taxonomy-root{display:grid;gap:.35rem;max-width:760px;margin:0 auto 1.4rem;padding:1rem;border-radius:16px;background:#2b2624;color:rgba(255,250,244,.82);text-align:center}
  .taxonomy-root a{color:#f4dfbd;font-size:1.1rem;font-weight:800}
  .taxonomy-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:1rem}
  .taxonomy-card{padding:1.2rem;border:1px solid rgba(176,160,140,.22);border-radius:18px;background:#fff;box-shadow:0 10px 28px rgba(0,0,0,.04)}
  .taxonomy-card-title{color:#3b332e;font-size:1.25rem;font-weight:800}
  .taxonomy-card p{margin:.5rem 0 1rem;color:#665b52;line-height:1.6}
  .taxonomy-card ul{display:grid;gap:.7rem;list-style:none;margin:0;padding:0}
  .taxonomy-card li{display:grid;gap:.15rem;padding-top:.7rem;border-top:1px solid rgba(176,160,140,.18)}
  .taxonomy-card li a{color:#8b7663;font-weight:800}
  .taxonomy-card li span{color:#756960;font-size:.9rem}
</style>
