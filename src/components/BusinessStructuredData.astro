---
// src/components/BusinessStructuredData.astro
import { businessContact } from '../data/businessContact.js';
import { siteConfig } from '../data/siteConfig.js';
import { getUsableSocials, isUsableContactValue } from '../utils/businessContactReadiness.js';

const siteUrl = siteConfig.url.replace(/\/$/, '');
const logoUrl = `${siteUrl}/images/logo-diamond.png`;

const socials = getUsableSocials(businessContact.socials)
  .map((social) => social.href);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'JewelryStore',
  '@id': `${siteUrl}/#business`,
  name: siteConfig.name,
  url: siteUrl,
  logo: logoUrl,
  image: logoUrl,
  description: 'Consultation-first diamond jewelry guidance for considered purchases.',
  ...(isUsableContactValue(businessContact.displayPhone) ? { telephone: businessContact.displayPhone } : {}),
  ...(isUsableContactValue(businessContact.email) ? { email: businessContact.email } : {}),
  ...(isUsableContactValue(businessContact.address) ? { address: businessContact.address } : {}),
  ...(isUsableContactValue(businessContact.businessHours) ? { openingHours: businessContact.businessHours } : {}),
  ...(socials.length > 0 ? { sameAs: socials } : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
