---
import { consultationSteps } from '../data/trustContent.js';
const { title = "How consultation-first buying works", description = "Dazzle should make high-value jewellery purchases feel verified, not rushed." } = Astro.props;
---
<section class="consultation-path" aria-labelledby="consultation-path-title">
  <div class="consultation-path-copy"><p>Process</p><h2 id="consultation-path-title">{title}</h2><span>{description}</span></div>
  <ol class="consultation-steps">
    {consultationSteps.map((step) => (<li><h3>{step.title}</h3><p>{step.body}</p></li>))}
  </ol>
</section>
<style>
  .consultation-path{display:grid;gap:1.5rem;margin:3rem 0;padding:2rem;border:1px solid rgba(176,160,140,.25);border-radius:24px;background:#fff}
  .consultation-path-copy p{margin:0 0 .35rem;color:#a0907c;font-size:.78rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
  .consultation-path-copy h2{margin:0 0 .65rem;color:#3b332e;font-size:clamp(1.8rem,4vw,2.7rem)}
  .consultation-path-copy span{color:#665b52;line-height:1.7}
  .consultation-steps{display:grid;gap:1rem;list-style:none;margin:0;padding:0;counter-reset:step}
  .consultation-steps li{counter-increment:step;position:relative;padding:1rem 1rem 1rem 4rem;border:1px solid rgba(176,160,140,.2);border-radius:18px;background:#fffaf4}
  .consultation-steps li::before{content:counter(step);position:absolute;left:1rem;top:1rem;display:grid;place-items:center;width:2rem;height:2rem;border-radius:999px;background:#2b2624;color:#f4dfbd;font-weight:800}
  .consultation-steps h3{margin:0 0 .35rem;color:#3b332e}.consultation-steps p{margin:0;color:#665b52;line-height:1.6}
  @media (min-width:900px){.consultation-path{grid-template-columns:.8fr 1.2fr;align-items:start}}
</style>
