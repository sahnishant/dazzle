---
import { businessContact } from '../data/businessContact.js';
import { buyingQuestions } from '../data/brandTrust.js';
const { title = 'Need help shortlisting?', productName = '' } = Astro.props;
const message = [
  'Hi Dazzle, I want help with laboratory-grown diamond jewellery.',
  productName ? `Product / page: ${productName}` : '',
  'Budget range:',
  'Preferred metal:',
  'Occasion and timeline:',
  'Please guide me with certification and final quote.',
].filter(Boolean).join('\n');
const whatsappHref = `https://wa.me/${businessContact.directMessageNumber}?text=${encodeURIComponent(message)}`;
---
<section class="lead-panel" aria-labelledby="lead-panel-title">
  <div>
    <p class="lead-kicker">Consultation-first buying</p>
    <h2 id="lead-panel-title">{title}</h2>
    <p>Use WhatsApp to share the occasion, budget, metal preference, timeline, and any reference image. The aim is clarity before commitment, not pressure.</p>
  </div>
  <ul>
    {buyingQuestions.map((question) => <li>{question}</li>)}
  </ul>
  <a class="btn" href={whatsappHref} target="_blank" rel="noopener noreferrer">Start WhatsApp Consultation</a>
</section>

<style>
  .lead-panel {
    display: grid;
    gap: 1.25rem;
    border-radius: 22px;
    background: linear-gradient(135deg, #2b2624 0%, #4a4038 100%);
    color: #fffaf4;
    padding: clamp(1.5rem, 4vw, 2.4rem);
    box-shadow: 0 18px 44px rgba(0,0,0,0.14);
  }
  .lead-panel h2 { color: #fffaf4; margin: 0 0 0.6rem; }
  .lead-panel p { color: rgba(255,250,244,0.86); margin: 0; }
  .lead-kicker { color: #f4dfbd !important; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; font-size: 0.8rem; }
  .lead-panel ul { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.55rem 1rem; margin: 0; padding-left: 1.1rem; }
  .lead-panel li { color: rgba(255,250,244,0.9); }
  .lead-panel .btn { justify-self: start; background: #f4dfbd; color: #2b2624; }
</style>
