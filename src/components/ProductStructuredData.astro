---
import { siteConfig } from '../data/siteConfig.js';
const { product } = Astro.props;
const baseUrl = siteConfig.url?.replace(/\/$/, '') || Astro.site?.toString().replace(/\/$/, '') || Astro.url.origin;
const productUrl = `${baseUrl}/collections/${product.category}/${product.id}/`;
const productImages = [product.mainImage, ...(product.additionalImages || [])].filter(Boolean).map((image) => new URL(image, baseUrl).toString());
const hasNumericPrice = Number.isFinite(product.priceValue) && Number(product.priceValue) > 0;
const additionalProperty = [
  product.diamondOrigin && { '@type': 'PropertyValue', name: 'Diamond origin', value: product.diamondOrigin },
  product.details?.growthMethod && { '@type': 'PropertyValue', name: 'Growth method', value: product.details.growthMethod },
  product.stoneType && { '@type': 'PropertyValue', name: 'Stone type', value: product.stoneType },
  product.details?.mainStone && { '@type': 'PropertyValue', name: 'Main stone', value: product.details.mainStone },
  product.details?.cut && { '@type': 'PropertyValue', name: 'Cut', value: product.details.cut },
  product.details?.color && { '@type': 'PropertyValue', name: 'Colour', value: product.details.color },
  product.details?.clarity && { '@type': 'PropertyValue', name: 'Clarity', value: product.details.clarity },
  product.details?.certification && { '@type': 'PropertyValue', name: 'Certification', value: product.details.certification },
  product.details?.certificateNumber && { '@type': 'PropertyValue', name: 'Certificate number', value: product.details.certificateNumber },
  product.metalPurity && { '@type': 'PropertyValue', name: 'Metal purity', value: product.metalPurity },
  product.metalHallmark && { '@type': 'PropertyValue', name: 'Metal hallmark', value: product.metalHallmark },
  product.leadTime && { '@type': 'PropertyValue', name: 'Lead time', value: product.leadTime },
].filter(Boolean);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: productImages,
  url: productUrl,
  sku: product.id,
  category: product.productType || product.category,
  brand: { '@type': 'Brand', name: 'Dazzle' },
  material: product.material || product.details?.metal,
  additionalProperty,
  offers: {
    '@type': 'Offer',
    url: productUrl,
    priceCurrency: 'INR',
    ...(hasNumericPrice ? { price: product.priceValue } : {}),
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    seller: { '@type': 'Organization', name: 'Dazzle' },
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
