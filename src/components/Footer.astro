---
// src/components/Footer.astro
---
<footer class="site-footer">
  <div class="container footer-content">
    <div class="footer-section">
      <h3>Dazzle</h3>
      <p>Consultation-first diamond jewelry guidance for considered purchases.</p>
      <p>© {new Date().getFullYear()} All rights reserved.</p>
    </div>
    <div class="footer-section">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/collections/">Collections</a></li>
        <li><a href="/about/">About Us</a></li>
        <li><a href="/contact/">Contact Us</a></li>
        <li><a href="/blog/">Blog & Insights</a></li>
        <li><a href="/policies/">Our Policies</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h4>Visit</h4>
      <p>Use the contact page to reach the boutique team for private consultations, custom design discussions, and product inquiries.</p>
      <p><a href="/contact/">Book a consultation</a></p>
    </div>
    <div class="footer-section social-media">
      <h4>Learn</h4>
      <a href="/diamond-grading/">Diamond Grading</a>
      <a href="/diamond-buyer-guide/">Buyer Guide</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #333;
    color: #f8f8f8;
    padding: 2rem 0;
    margin-top: 3rem;
  }
  .footer-content {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2rem;
  }
  .footer-section {
    flex: 1;
    min-width: 200px;
  }
  .footer-section h3, .footer-section h4 {
    color: #B0A08C;
    margin-bottom: 1rem;
  }
  .footer-section p {
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .footer-section ul {
    list-style: none;
  }
  .footer-section ul li {
    margin-bottom: 0.5rem;
  }
  .footer-section a {
    color: #f8f8f8;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }
  .footer-section a:hover {
    color: #B0A08C;
  }
  .social-media a {
    display: inline-block;
    margin-right: 1rem;
    margin-top: 0.5rem;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-section {
      width: 100%;
    }
  }
</style>