---
// src/pages/collections/[category]/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { jewelryItems } from '../../../data/jewelry.js';

export async function getStaticPaths() {
  const categories = [...new Set(
    jewelryItems
      .map((item) => item?.category)
      .filter((category) => typeof category === 'string' && category.length > 0)
  )];

  return categories.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const displayCategoryName = category
  ? category.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase())
  : 'Collection';

const categoryItems = jewelryItems
  .filter((item) => item.category === category)
  .sort((a, b) => {
    const dateA = a.dateAdded instanceof Date ? a.dateAdded.getTime() : 0;
    const dateB = b.dateAdded instanceof Date ? b.dateAdded.getTime() : 0;
    return dateB - dateA;
  });

const buildOptions = (key) => Object.entries(
  categoryItems.reduce((counts, item) => {
    const value = item[key];
    if (!value) return counts;
    counts[value] = (counts[value] || 0) + 1;
    return counts;
  }, {})
)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([value, count]) => ({ value, count }));

const materials = buildOptions('material');
const stoneTypes = buildOptions('stoneType');
const styles = buildOptions('style');
const pageDescription = `Browse ${displayCategoryName.toLowerCase()} by material, stone type, style, and price.`;
---

<BaseLayout title={`${displayCategoryName} Collection`} description={pageDescription}>
  <section class="container page-section category-page" data-category-slug={category}>
    <div class="category-hero">
      <p class="category-kicker">Dazzle collection</p>
      <h1>{displayCategoryName} Collection</h1>
      <p>{pageDescription}</p>
    </div>

    <div class="mobile-filter-sort-toggles">
      <button id="mobileFilterBtn" class="btn btn-outline mobile-toggle-btn" type="button">Filter</button>
      <div class="sort-options mobile-sort-inline">
        <label for="sortOrderMobile">Sort by</label>
        <select id="sortOrderMobile" data-sort-control>
          <option value="newest">Newest</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
          <option value="popularity-desc">Popularity</option>
        </select>
      </div>
    </div>

    <div class="collection-layout">
      <aside id="filtersSidebar" class="filters-sidebar" aria-label="Collection filters">
        <div class="sidebar-header">
          <div>
            <p class="category-kicker">Refine</p>
            <h2>Filter pieces</h2>
          </div>
          <button id="closeFilterSidebar" class="close-btn" type="button" aria-label="Close filters">×</button>
        </div>

        <button id="clearFilters" class="btn btn-outline small-btn mb-4 w-full" type="button">Clear Filters</button>

        {materials.length > 0 && (
          <fieldset class="filter-group">
            <legend>Material</legend>
            {materials.map((option) => (
              <label>
                <input type="checkbox" data-filter-type="material" value={option.value} />
                <span>{option.value}</span>
                <small>{option.count}</small>
              </label>
            ))}
          </fieldset>
        )}

        {stoneTypes.length > 0 && (
          <fieldset class="filter-group">
            <legend>Stone Type</legend>
            {stoneTypes.map((option) => (
              <label>
                <input type="checkbox" data-filter-type="stoneType" value={option.value} />
                <span>{option.value}</span>
                <small>{option.count}</small>
              </label>
            ))}
          </fieldset>
        )}

        {styles.length > 0 && (
          <fieldset class="filter-group">
            <legend>Style</legend>
            {styles.map((option) => (
              <label>
                <input type="checkbox" data-filter-type="style" value={option.value} />
                <span>{option.value}</span>
                <small>{option.count}</small>
              </label>
            ))}
          </fieldset>
        )}

        <fieldset class="filter-group">
          <legend>Price Range</legend>
          <label><input type="checkbox" data-filter-type="priceRange" value="0-100000" /> <span>Under ₹1 Lakh</span></label>
          <label><input type="checkbox" data-filter-type="priceRange" value="100001-300000" /> <span>₹1 Lakh - ₹3 Lakh</span></label>
          <label><input type="checkbox" data-filter-type="priceRange" value="300001-700000" /> <span>₹3 Lakh - ₹7 Lakh</span></label>
          <label><input type="checkbox" data-filter-type="priceRange" value="700001-999999999" /> <span>₹7 Lakh +</span></label>
        </fieldset>

        <button id="applyFiltersBtn" class="btn w-full mt-4 mobile-only" type="button">Apply Filters</button>
      </aside>

      <div class="main-collection-content">
        <div class="collection-toolbar">
          <p id="categoryResultCount">Showing {categoryItems.length} {categoryItems.length === 1 ? 'piece' : 'pieces'}</p>
          <div class="sort-options desktop-sort-inline">
            <label for="sortOrderDesktop">Sort by</label>
            <select id="sortOrderDesktop" data-sort-control>
              <option value="newest">Newest</option>
              <option value="price-asc">Price: Low to High</option>
              <option value="price-desc">Price: High to Low</option>
              <option value="popularity-desc">Popularity</option>
            </select>
          </div>
        </div>

        <div id="activeFilterChips" class="active-filter-chips" aria-label="Active filters"></div>

        <div id="productGrid" class="product-grid">
          {categoryItems.map((item) => (
            <article
              class="product-card"
              data-product-card
              data-id={item.id}
              data-name={item.name}
              data-price={item.price}
              data-price-value={item.priceValue || 0}
              data-popularity={item.popularityScore || 0}
              data-date={item.dateAdded instanceof Date ? item.dateAdded.toISOString() : ''}
              data-material={item.material || ''}
              data-stone-type={item.stoneType || ''}
              data-style={item.style || ''}
            >
              <a href={`/collections/${item.category}/${item.id}/`} class="product-card-link">
                <img src={item.mainImage} alt={item.name} loading="lazy" />
                <div class="product-info-card">
                  <p class="product-meta">{item.material} · {item.style}</p>
                  <h3>{item.name}</h3>
                  <p class="price">{item.price}</p>
                </div>
              </a>
              <div class="card-actions">
                <a href={`/collections/${item.category}/${item.id}/`} class="small-link">View Details</a>
                <a href={`/contact/?item=${item.id}`} class="small-link">Inquire</a>
              </div>
            </article>
          ))}
        </div>

        <div id="emptyCollectionState" class="empty-state" hidden>
          <p class="category-kicker">No exact match</p>
          <h2>No pieces match these filters</h2>
          <p>Clear the filters or contact us for a recommendation based on your preferred style, material, and budget.</p>
          <div class="empty-actions">
            <button id="clearEmptyFilters" class="btn" type="button">Clear Filters</button>
            <a href="/contact/" class="secondary-link">Request Guidance</a>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-8">
      <a href="/collections/" class="btn btn-outline">← Back to All Collections</a>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('filtersSidebar');
    const mobileFilterBtn = document.getElementById('mobileFilterBtn');
    const closeFilterSidebar = document.getElementById('closeFilterSidebar');
    const applyFiltersBtn = document.getElementById('applyFiltersBtn');
    const clearFiltersBtn = document.getElementById('clearFilters');
    const clearEmptyFiltersBtn = document.getElementById('clearEmptyFilters');
    const filterCheckboxes = Array.from(document.querySelectorAll('#filtersSidebar input[type="checkbox"]'));
    const sortControls = Array.from(document.querySelectorAll('[data-sort-control]'));
    const productGrid = document.getElementById('productGrid');
    const cards = Array.from(document.querySelectorAll('[data-product-card]'));
    const resultCount = document.getElementById('categoryResultCount');
    const emptyState = document.getElementById('emptyCollectionState');
    const activeFilterChips = document.getElementById('activeFilterChips');

    const filterTypes = ['material', 'stoneType', 'style', 'priceRange'];

    const getActiveFilters = () => filterCheckboxes
      .filter((checkbox) => checkbox.checked)
      .map((checkbox) => ({
        type: checkbox.dataset.filterType,
        value: checkbox.value,
        label: checkbox.nextElementSibling?.textContent?.trim() || checkbox.value,
      }));

    const syncSortControls = (changedControl) => {
      sortControls.forEach((control) => {
        if (control !== changedControl) control.value = changedControl.value;
      });
    };

    const getSortValue = () => sortControls.find((control) => control.offsetParent !== null)?.value || sortControls[0]?.value || 'newest';

    const matchesPriceRange = (priceValue, range) => {
      const [min, max] = range.split('-').map(Number);
      return priceValue >= min && priceValue <= max;
    };

    const getSelectedValues = (type) => filterCheckboxes
      .filter((checkbox) => checkbox.dataset.filterType === type && checkbox.checked)
      .map((checkbox) => checkbox.value);

    const renderActiveChips = () => {
      if (!activeFilterChips) return;
      const filters = getActiveFilters();
      activeFilterChips.innerHTML = '';

      filters.forEach((filter) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'active-filter-chip';
        chip.textContent = `${filter.label} ×`;
        chip.addEventListener('click', () => {
          const checkbox = filterCheckboxes.find((candidate) => candidate.dataset.filterType === filter.type && candidate.value === filter.value);
          if (checkbox) checkbox.checked = false;
          applyFiltersAndSort();
        });
        activeFilterChips.appendChild(chip);
      });
    };

    const sortCards = (visibleCards) => {
      const sortValue = getSortValue();
      return visibleCards.sort((a, b) => {
        if (sortValue === 'price-asc') return Number(a.dataset.priceValue || 0) - Number(b.dataset.priceValue || 0);
        if (sortValue === 'price-desc') return Number(b.dataset.priceValue || 0) - Number(a.dataset.priceValue || 0);
        if (sortValue === 'popularity-desc') return Number(b.dataset.popularity || 0) - Number(a.dataset.popularity || 0);
        return new Date(b.dataset.date || 0).getTime() - new Date(a.dataset.date || 0).getTime();
      });
    };

    const applyFiltersAndSort = () => {
      const selected = Object.fromEntries(filterTypes.map((type) => [type, getSelectedValues(type)]));
      const visibleCards = [];

      cards.forEach((card) => {
        const priceValue = Number(card.dataset.priceValue || 0);
        const isVisible = filterTypes.every((type) => {
          if (selected[type].length === 0) return true;
          if (type === 'priceRange') return selected[type].some((range) => matchesPriceRange(priceValue, range));
          return selected[type].includes(card.dataset[type]);
        });

        card.hidden = !isVisible;
        if (isVisible) visibleCards.push(card);
      });

      sortCards(visibleCards).forEach((card) => productGrid?.appendChild(card));

      if (resultCount) {
        resultCount.textContent = `Showing ${visibleCards.length} ${visibleCards.length === 1 ? 'piece' : 'pieces'}`;
      }

      if (emptyState) {
        emptyState.hidden = visibleCards.length > 0;
      }

      renderActiveChips();
    };

    const clearFilters = () => {
      filterCheckboxes.forEach((checkbox) => {
        checkbox.checked = false;
      });
      applyFiltersAndSort();
    };

    mobileFilterBtn?.addEventListener('click', () => sidebar?.classList.add('is-open'));
    closeFilterSidebar?.addEventListener('click', () => sidebar?.classList.remove('is-open'));
    applyFiltersBtn?.addEventListener('click', () => sidebar?.classList.remove('is-open'));
    clearFiltersBtn?.addEventListener('click', clearFilters);
    clearEmptyFiltersBtn?.addEventListener('click', clearFilters);
    filterCheckboxes.forEach((checkbox) => checkbox.addEventListener('change', applyFiltersAndSort));
    sortControls.forEach((control) => control.addEventListener('change', () => {
      syncSortControls(control);
      applyFiltersAndSort();
    }));

    applyFiltersAndSort();
  });
</script>

<style>
  .page-section {
    padding: 3rem 1rem;
    background-color: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 26px rgba(0,0,0,0.06);
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .category-hero {
    max-width: 820px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .category-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .category-hero h1 {
    margin: 0 0 0.75rem;
    color: #555;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
  }

  .category-hero p {
    margin: 0;
    color: #666;
    line-height: 1.7;
  }

  .mobile-filter-sort-toggles {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .collection-layout {
    display: grid;
    gap: 1.5rem;
  }

  .filters-sidebar {
    padding: 1.25rem;
    border: 1px solid rgba(176, 160, 140, 0.28);
    border-radius: 14px;
    background: #fffaf4;
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .sidebar-header h2 {
    margin: 0;
    color: #555;
    font-size: 1.3rem;
  }

  .close-btn {
    border: 0;
    background: transparent;
    color: #555;
    cursor: pointer;
    font-size: 1.6rem;
  }

  .filter-group {
    border: 0;
    margin: 0 0 1.25rem;
    padding: 0;
  }

  .filter-group legend {
    margin-bottom: 0.65rem;
    color: #555;
    font-weight: 700;
  }

  .filter-group label {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.55rem;
    align-items: center;
    margin-bottom: 0.55rem;
    color: #555;
    cursor: pointer;
  }

  .filter-group input {
    accent-color: #B0A08C;
  }

  .filter-group small {
    display: inline-flex;
    min-width: 1.65rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(176, 160, 140, 0.16);
    color: #8a7663;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.65;
  }

  .collection-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .collection-toolbar p {
    margin: 0;
    color: #666;
    font-weight: 700;
  }

  .sort-options {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .sort-options label {
    color: #555;
    font-weight: 700;
  }

  .sort-options select {
    border: 1px solid rgba(176, 160, 140, 0.42);
    border-radius: 999px;
    background: #fff;
    color: #555;
    padding: 0.45rem 0.75rem;
  }

  .active-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .active-filter-chip {
    border: 1px solid rgba(176, 160, 140, 0.4);
    border-radius: 999px;
    background: #fffaf4;
    color: #7d6d5b;
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.4rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(176, 160, 140, 0.2);
    border-radius: 14px;
    background-color: white;
    box-shadow: 0 6px 18px rgba(0,0,0,0.06);
  }

  .product-card-link {
    display: flex;
    flex: 1;
    flex-direction: column;
    color: #333;
    text-decoration: none;
  }

  .product-card img {
    width: 100%;
    height: 230px;
    object-fit: cover;
  }

  .product-info-card {
    padding: 1rem;
  }

  .product-meta {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-info-card h3 {
    margin: 0 0 0.75rem;
    color: #555;
    font-size: 1.12rem;
  }

  .price {
    margin: 0;
    color: #B0A08C;
    font-weight: 700;
  }

  .card-actions {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1rem 1rem;
  }

  .small-link,
  .secondary-link {
    color: #A0907C;
    font-weight: 700;
  }

  .empty-state {
    margin-top: 1.5rem;
    padding: 2rem;
    border: 1px solid rgba(176, 160, 140, 0.35);
    border-radius: 16px;
    background: #fffaf4;
    text-align: center;
  }

  .empty-state h2 {
    color: #555;
  }

  .empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .desktop-sort-inline {
    display: none;
  }

  .mobile-only {
    display: inline-flex;
  }

  @media (max-width: 767px) {
    .filters-sidebar {
      position: fixed;
      inset: 0 0 0 auto;
      z-index: 50;
      width: min(88vw, 360px);
      overflow-y: auto;
      transform: translateX(105%);
      transition: transform 0.25s ease;
      box-shadow: -12px 0 30px rgba(0,0,0,0.15);
    }

    .filters-sidebar.is-open {
      transform: translateX(0);
    }
  }

  @media (min-width: 768px) {
    .collection-layout {
      grid-template-columns: minmax(220px, 280px) 1fr;
      align-items: start;
    }

    .filters-sidebar {
      position: sticky;
      top: 1rem;
    }

    .desktop-sort-inline {
      display: flex;
    }

    .mobile-sort-inline,
    .mobile-toggle-btn,
    .mobile-only,
    .close-btn {
      display: none;
    }
  }
</style>
