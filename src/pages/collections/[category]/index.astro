---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbStructuredData from '../../../components/BreadcrumbStructuredData.astro';
import CollectionStructuredData from '../../../components/CollectionStructuredData.astro';
import DiamondTaxonomyNav from '../../../components/DiamondTaxonomyNav.astro';
import ProductContactActions from '../../../components/ProductContactActions.astro';
import TrustLedger from '../../../components/TrustLedger.astro';
import { jewelryItems } from '../../../data/jewelry.js';
import { getCategoryContent } from '../../../data/categoryContent.js';

const categories = Array.from(new Set(jewelryItems.map((item) => item.category)));

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      products: jewelryItems.filter((item) => item.category === category),
    },
  }));
}

const { category, products } = Astro.props;
const content = getCategoryContent(category);
const formatLabel = (value) => value.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Collections', path: '/collections/' },
  { name: formatLabel(category), path: `/collections/${category}/` },
];

const featuredProduct = products[0];
---

<BaseLayout title={content.title} description={content.description}>
  <BreadcrumbStructuredData items={breadcrumbs} />
  <CollectionStructuredData name={content.title} description={content.description} products={products} />

  <main class="container category-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((crumb, index) => (
          <li>
            {index < breadcrumbs.length - 1 ? <a href={crumb.path}>{crumb.name}</a> : <span>{crumb.name}</span>}
            {index < breadcrumbs.length - 1 && <span class="separator">/</span>}
          </li>
        ))}
      </ol>
    </nav>

    <section class="category-hero">
      <p class="category-kicker">Dazzle collection</p>
      <h1>{content.h1}</h1>
      <p>{content.intro}</p>
      <div class="category-actions">
        <a href="#category-products" class="btn">View designs</a>
        <a href="/laboratory-grown-diamond-consultation/" class="btn btn-outline">Start consultation</a>
      </div>
    </section>

    <section class="category-guidance" aria-labelledby="category-guidance-title">
      <div>
        <p class="category-kicker">Buyer notes</p>
        <h2 id="category-guidance-title">What to confirm before payment</h2>
      </div>
      <ul>
        {content.buyerNotes.map((note) => <li>{note}</li>)}
      </ul>
    </section>

    <section class="category-links" aria-label="Related guides">
      {content.guideLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </section>

    <section id="category-products" class="category-products" aria-labelledby="category-products-title">
      <div class="section-heading">
        <p class="category-kicker">{products.length} designs</p>
        <h2 id="category-products-title">Browse {formatLabel(category)}</h2>
      </div>

      <div class="product-grid">
        {products.map((item) => (
          <article class="product-card">
            <a href={`/collections/${item.category}/${item.id}/`}>
              <Image
                src={item.mainImage}
                alt={item.name}
                width={760}
                height={600}
                format="webp"
                loading="lazy"
                decoding="async"
                class="product-card-image"
              />
              <div class="product-card-copy">
                <p>{item.diamondOrigin || item.stoneType || 'Laboratory-grown diamond'}</p>
                <h3>{item.name}</h3>
                <span>{item.price}</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    {featuredProduct && (
      <section class="category-consultation">
        <div>
          <p class="category-kicker">Need guidance?</p>
          <h2>Ask Dazzle to shortlist {formatLabel(category)}</h2>
          <p>Share your budget, city, metal preference, and timeline. Dazzle can suggest suitable designs and verification steps.</p>
        </div>
        <ProductContactActions product={featuredProduct} sourcePage={`/collections/${category}/`} />
      </section>
    )}

    <TrustLedger compact={true} />
    <DiamondTaxonomyNav />
  </main>
</BaseLayout>

<style>
  .category-page {
    padding-bottom: 4rem;
  }

  .breadcrumbs {
    margin: 1.5rem 0;
    color: #7b7169;
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .separator {
    color: #b7aaa0;
    margin-left: 0.35rem;
  }

  .category-hero {
    padding: clamp(2rem, 6vw, 4rem);
    border-radius: 28px;
    background:
      radial-gradient(circle at 18% 18%, rgba(244, 223, 189, 0.24), transparent 35%),
      linear-gradient(135deg, #2b2624, #4b4038);
    color: #fffaf4;
  }

  .category-kicker {
    margin: 0 0 0.45rem;
    color: #a0907c;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .category-hero .category-kicker {
    color: #f4dfbd;
  }

  .category-hero h1 {
    max-width: 880px;
    margin: 0 0 1rem;
    color: #fffaf4;
    font-size: clamp(2.3rem, 6vw, 4.6rem);
    line-height: 1;
  }

  .category-hero p:not(.category-kicker) {
    max-width: 780px;
    color: rgba(255, 250, 244, 0.86);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .category-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .category-actions .btn-outline {
    border-color: rgba(244, 223, 189, 0.8);
    color: #f4dfbd;
  }

  .category-actions .btn-outline:hover {
    background: #f4dfbd;
    color: #2b2624;
  }

  .category-guidance,
  .category-consultation {
    display: grid;
    gap: 1.25rem;
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid rgba(176, 160, 140, 0.24);
    border-radius: 22px;
    background: #fffaf4;
  }

  .category-guidance h2,
  .category-consultation h2 {
    margin: 0;
    color: #3b332e;
  }

  .category-guidance ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1.2rem;
    color: #665b52;
    line-height: 1.65;
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 1.5rem 0 2.5rem;
  }

  .category-links a {
    display: inline-flex;
    border: 1px solid rgba(176, 160, 140, 0.32);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    background: #fff;
    color: #7d6d5b;
    font-weight: 800;
  }

  .section-heading {
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .section-heading h2 {
    margin: 0;
    color: #3b332e;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.25rem;
  }

  .product-card {
    overflow: hidden;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
  }

  .product-card a {
    display: grid;
    min-height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .product-card-image {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  .product-card-copy {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .product-card-copy p {
    margin: 0;
    color: #a0907c;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-card-copy h3 {
    margin: 0;
    color: #3b332e;
    font-size: 1.08rem;
    line-height: 1.35;
  }

  .product-card-copy span {
    color: #8b7663;
    font-weight: 800;
  }

  .category-consultation p:not(.category-kicker) {
    color: #665b52;
    line-height: 1.7;
  }

  @media (min-width: 860px) {
    .category-guidance,
    .category-consultation {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: start;
    }
  }
</style>
