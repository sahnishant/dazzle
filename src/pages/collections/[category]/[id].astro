---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbStructuredData from '../../../components/BreadcrumbStructuredData.astro';
import CustomInquiryForm from '../../../components/CustomInquiryForm.astro';
import ProductContactActions from '../../../components/ProductContactActions.astro';
import ProductFaq from '../../../components/ProductFaq.astro';
import ProductStructuredData from '../../../components/ProductStructuredData.astro';
import ProductTrustPanel from '../../../components/ProductTrustPanel.astro';
import TrustLedger from '../../../components/TrustLedger.astro';
import { jewelryItems } from '../../../data/jewelry.js';

export async function getStaticPaths() {
  return jewelryItems.map((item) => ({
    params: { category: item.category, id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const isCustomProduct = item.category === 'custom';
const allImages = [item.mainImage, ...(item.additionalImages || [])].filter(Boolean);
const formatLabel = (value) => value.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Collections', path: '/collections/' },
  { name: formatLabel(item.category), path: `/collections/${item.category}/` },
  { name: item.name, path: `/collections/${item.category}/${item.id}/` },
];

const detailRows = Object.entries(item.details || {});
---

<BaseLayout title={item.name} description={item.description} image={item.mainImage} type="product">
  <ProductStructuredData product={item} />
  <BreadcrumbStructuredData items={breadcrumbs} />

  <main class="container product-detail-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((crumb, index) => (
          <li>
            {index < breadcrumbs.length - 1 ? <a href={crumb.path}>{crumb.name}</a> : <span>{crumb.name}</span>}
            {index < breadcrumbs.length - 1 && <span class="separator">/</span>}
          </li>
        ))}
      </ol>
    </nav>

    <section class="product-layout">
      <div class="product-images">
        {allImages.length > 0 && (
          <Image
            id="mainProductImage"
            src={allImages[0]}
            alt={item.name}
            width={900}
            height={900}
            format="webp"
            loading="eager"
            decoding="async"
            class="main-product-image"
          />
        )}

        {allImages.length > 1 && (
          <div class="thumbnail-gallery" aria-label="Product image gallery">
            {allImages.map((img, index) => (
              <img
                src={img}
                alt={`${item.name} - view ${index + 1}`}
                loading="lazy"
                class={`thumbnail ${index === 0 ? 'active' : ''}`}
                data-full-src={img}
              />
            ))}
          </div>
        )}
      </div>

      <div class="product-info">
        <p class="product-kicker">{isCustomProduct ? 'Custom consultation' : 'Dazzle verified shortlist'}</p>
        <h1>{item.name}</h1>
        <p class="product-price">{item.price}</p>

        <div class="product-reassurance" aria-label="Purchase reassurance">
          <span>{item.diamondOrigin || 'Laboratory-grown diamond'}</span>
          <span>{item.certificationLab || item.details?.certification || 'Certificate guidance'}</span>
          <span>{item.metalPurity || item.material}</span>
        </div>

        <ProductTrustPanel product={item} />

        <section class="product-section">
          <h2>Description</h2>
          <p>{item.description}</p>
        </section>

        {detailRows.length > 0 && (
          <section class="product-section">
            <h2>Stone and jewellery details</h2>
            <dl class="details-list">
              {detailRows.map(([key, value]) => (
                <div>
                  <dt>{formatLabel(key)}</dt>
                  <dd>{value}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}

        <section class="product-section">
          <h2>Before you order</h2>
          <ul class="order-checklist">
            <li>Confirm final laboratory-grown diamond certificate details.</li>
            <li>Confirm metal purity and hallmarking expectation.</li>
            <li>Confirm final price, making details, delivery city, and timeline.</li>
            <li>Read custom-order, return/exchange, and shipping policy before advance payment.</li>
          </ul>
        </section>

        {item.dimensions && (
          <section class="product-section">
            <h2>Dimensions</h2>
            <p>{item.dimensions}</p>
          </section>
        )}

        {item.uniqueFeatures && (
          <section class="product-section">
            <h2>Design notes</h2>
            <p>{item.uniqueFeatures}</p>
          </section>
        )}

        {item.careInstructions && (
          <section class="product-section">
            <h2>Care guidance</h2>
            <p>{item.careInstructions}</p>
          </section>
        )}

        <ProductContactActions product={item} showContactLink={!isCustomProduct} />
        {isCustomProduct && <CustomInquiryForm productTitle={item.name} productId={item.id} />}
        <ProductFaq product={item} />
      </div>
    </section>

    <TrustLedger compact={true} />
  </main>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const mainImage = document.getElementById('mainProductImage');
    const thumbnails = document.querySelectorAll('.thumbnail-gallery .thumbnail');

    if (mainImage && thumbnails.length > 0) {
      thumbnails.forEach((thumbnail) => {
        thumbnail.addEventListener('click', () => {
          thumbnails.forEach((candidate) => candidate.classList.remove('active'));
          thumbnail.classList.add('active');
          mainImage.src = thumbnail.dataset.fullSrc;
        });
      });
    }
  });
</script>

<style>
  .product-detail-page {
    padding-bottom: 4rem;
  }

  .breadcrumbs {
    margin: 1.5rem 0;
    color: #7b7169;
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .separator {
    color: #b7aaa0;
    margin-left: 0.35rem;
  }

  .product-layout {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .product-images {
    display: grid;
    gap: 1rem;
  }

  .main-product-image {
    width: 100%;
    border: 1px solid rgba(176, 160, 140, 0.22);
    border-radius: 24px;
    background: #fff;
    object-fit: cover;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.08);
  }

  .thumbnail-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .thumbnail {
    width: 78px;
    height: 78px;
    border: 1px solid rgba(176, 160, 140, 0.35);
    border-radius: 12px;
    cursor: pointer;
    object-fit: cover;
  }

  .thumbnail.active,
  .thumbnail:hover {
    border-color: #B0A08C;
    box-shadow: 0 0 0 2px rgba(176, 160, 140, 0.35);
  }

  .product-info {
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid rgba(176, 160, 140, 0.18);
    border-radius: 24px;
    background: #fff;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.06);
  }

  .product-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .product-info h1 {
    margin: 0 0 0.75rem;
    color: #3b332e;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1;
  }

  .product-price {
    margin: 0 0 1rem;
    color: #B0A08C;
    font-size: 1.6rem;
    font-weight: 800;
  }

  .product-reassurance {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .product-reassurance span {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(176, 160, 140, 0.3);
    border-radius: 999px;
    background: #fffaf4;
    color: #7d6d5b;
    font-size: 0.82rem;
    font-weight: 800;
    padding: 0.35rem 0.7rem;
  }

  .product-section {
    margin: 1.5rem 0;
  }

  .product-section h2 {
    margin: 0 0 0.75rem;
    color: #3b332e;
    font-size: 1.35rem;
  }

  .product-section p,
  .order-checklist {
    color: #665b52;
    line-height: 1.7;
  }

  .details-list {
    display: grid;
    gap: 0.65rem;
    margin: 0;
  }

  .details-list div {
    display: grid;
    gap: 0.15rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(176, 160, 140, 0.18);
  }

  .details-list dt {
    color: #8b7663;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .details-list dd {
    margin: 0;
    color: #3f3832;
  }

  .order-checklist {
    margin: 0;
    padding-left: 1.2rem;
  }

  @media (min-width: 900px) {
    .product-layout {
      grid-template-columns: minmax(0, 1.05fr) minmax(380px, 0.95fr);
    }

    .product-images {
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
