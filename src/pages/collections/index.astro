---
// src/pages/collections/index.astro
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionGrid from '../../components/CollectionGrid.astro';
import FilterSidebar from '../../components/FilterSidebar.astro';
import { jewelryItems } from '../../data/jewelry.js';

const collections = [
  { name: 'Rings', image: '/images/collection-rings.png', link: '/collections/rings/' },
  { name: 'Necklaces', image: '/images/collection-necklaces.png', link: '/collections/necklaces/' },
  { name: 'Earrings', image: '/images/collection-earrings.png', link: '/collections/earrings/' },
  { name: 'Bracelets', image: '/images/collection-bracelets.png', link: '/collections/bracelets/' },
  { name: 'Custom Designs', image: '/images/collection-custom.webp', link: '/collections/custom/' },
];

const formatLabel = (value) => value.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
const buildOptions = (key, formatter = formatLabel) => Object.entries(
  jewelryItems.reduce((counts, item) => {
    const value = item[key];
    if (!value) return counts;
    counts[value] = (counts[value] || 0) + 1;
    return counts;
  }, {})
)
  .sort(([a], [b]) => formatter(a).localeCompare(formatter(b)))
  .map(([value, count]) => ({ value, label: formatter(value), count }));

const categories = buildOptions('category');
const materials = buildOptions('material', (value) => value);
const styles = buildOptions('style', (value) => value);
---
<BaseLayout title="Collections" description="Browse our exquisite diamond jewelry collections by type, material, and design style.">
  <section class="container mt-4 mb-4 collections-page">
    <div class="collections-heading">
      <p class="collections-kicker">Boutique catalogue</p>
      <h1>Our Jewelry Collections</h1>
      <p>Browse by collection, or refine the full catalogue by category, material, and design style.</p>
    </div>

    <CollectionGrid collections={collections} />

    <div class="browse-section" id="browse-all-pieces">
      <div class="browse-heading">
        <p class="collections-kicker">All pieces</p>
        <h2>Browse every design</h2>
        <p id="collectionResultCount">Showing {jewelryItems.length} pieces</p>
      </div>

      <div class="active-filter-row" id="activeFilterRow" hidden>
        <span>Active filters</span>
        <div id="activeFilterChips" class="active-filter-chips"></div>
      </div>

      <div class="browse-layout">
        <FilterSidebar categories={categories} materials={materials} styles={styles} />

        <div class="product-results" id="collectionProductGrid">
          {jewelryItems.map((item) => (
            <article
              class="collection-product-card"
              data-product-card
              data-category={item.category}
              data-category-label={formatLabel(item.category)}
              data-material={item.material}
              data-material-label={item.material}
              data-style={item.style}
              data-style-label={item.style}
            >
              <a href={`/collections/${item.category}/${item.id}/`}>
                <Image
                  src={item.mainImage}
                  alt={item.name}
                  width={760}
                  height={600}
                  format="webp"
                  loading="lazy"
                  decoding="async"
                  class="collection-product-image"
                />
                <div class="collection-product-copy">
                  <p class="collection-product-meta">{formatLabel(item.category)} · {item.material} · {item.style}</p>
                  <h3>{item.name}</h3>
                  <p class="collection-product-price">{item.price}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>

      <div id="emptyCollectionState" class="empty-state" hidden>
        <p class="empty-kicker">No exact match</p>
        <h3>No pieces match the selected filters</h3>
        <p>Clear the filters to return to the full catalogue, or contact us for a custom recommendation based on your preference.</p>
        <div class="empty-actions">
          <button type="button" id="clearEmptyStateFilters" class="btn">Clear filters</button>
          <a href="/contact/" class="empty-link">Request guidance</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const filterInputs = Array.from(document.querySelectorAll('[data-collection-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-product-card]'));
    const clearButton = document.getElementById('clearCollectionFilters');
    const emptyClearButton = document.getElementById('clearEmptyStateFilters');
    const resultCount = document.getElementById('collectionResultCount');
    const emptyState = document.getElementById('emptyCollectionState');
    const activeFilterRow = document.getElementById('activeFilterRow');
    const activeFilterChips = document.getElementById('activeFilterChips');

    const filterTypes = ['category', 'material', 'style'];

    const getCheckedValues = (type) => new Set(
      filterInputs
        .filter((input) => input.dataset.collectionFilter === type && input.checked)
        .map((input) => input.value)
    );

    const getActiveFilters = () => filterInputs
      .filter((input) => input.checked)
      .map((input) => ({
        type: input.dataset.collectionFilter,
        value: input.value,
        label: input.nextElementSibling?.textContent || input.value,
      }));

    const updateActiveChips = () => {
      const activeFilters = getActiveFilters();

      if (!activeFilterRow || !activeFilterChips) return;

      activeFilterRow.hidden = activeFilters.length === 0;
      activeFilterChips.innerHTML = '';

      activeFilters.forEach((filter) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'active-filter-chip';
        chip.textContent = `${filter.label} ×`;
        chip.addEventListener('click', () => {
          const input = filterInputs.find((candidate) => (
            candidate.dataset.collectionFilter === filter.type && candidate.value === filter.value
          ));
          if (input) input.checked = false;
          applyFilters();
        });
        activeFilterChips.appendChild(chip);
      });
    };

    const applyFilters = () => {
      const selectedValues = Object.fromEntries(
        filterTypes.map((type) => [type, getCheckedValues(type)])
      );
      let visibleCount = 0;

      cards.forEach((card) => {
        const isVisible = filterTypes.every((type) => (
          selectedValues[type].size === 0 || selectedValues[type].has(card.dataset[type])
        ));

        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (resultCount) {
        resultCount.textContent = `Showing ${visibleCount} ${visibleCount === 1 ? 'piece' : 'pieces'}`;
      }

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }

      updateActiveChips();
    };

    const clearFilters = () => {
      filterInputs.forEach((input) => {
        input.checked = false;
      });
      applyFilters();
    };

    filterInputs.forEach((input) => input.addEventListener('change', applyFilters));
    clearButton?.addEventListener('click', clearFilters);
    emptyClearButton?.addEventListener('click', clearFilters);

    applyFilters();
  });
</script>

<style>
  .collections-page {
    padding-bottom: 3rem;
  }

  .collections-heading,
  .browse-heading {
    max-width: 760px;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .collections-heading h1,
  .browse-heading h2 {
    margin: 0 0 0.75rem;
    color: #555;
  }

  .collections-heading p:last-child,
  .browse-heading p:last-child {
    margin: 0;
    color: #666;
    line-height: 1.65;
  }

  .collections-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .browse-section {
    margin-top: 4rem;
  }

  .active-filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    margin: -0.75rem auto 1.5rem;
    color: #666;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .active-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .active-filter-chip {
    border: 1px solid rgba(176, 160, 140, 0.4);
    border-radius: 999px;
    background: #fffaf4;
    color: #7d6d5b;
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
  }

  .active-filter-chip:hover,
  .active-filter-chip:focus-visible {
    background: #B0A08C;
    color: #fff;
  }

  .browse-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .product-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.4rem;
  }

  .collection-product-card {
    overflow: hidden;
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.07);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .collection-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.1);
  }

  .collection-product-card a {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    color: #333;
    text-decoration: none;
  }

  .collection-product-image {
    width: 100%;
    height: 230px;
    object-fit: cover;
  }

  .collection-product-copy {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem;
  }

  .collection-product-meta {
    margin: 0 0 0.4rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collection-product-copy h3 {
    margin: 0 0 0.75rem;
    color: #555;
    font-size: 1.1rem;
    line-height: 1.35;
  }

  .collection-product-price {
    margin: auto 0 0;
    color: #B0A08C;
    font-weight: 700;
  }

  .empty-state {
    margin: 2rem auto 0;
    max-width: 720px;
    padding: 2rem;
    border: 1px solid rgba(176, 160, 140, 0.4);
    border-radius: 16px;
    color: #666;
    text-align: center;
    background: #fffaf4;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .empty-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .empty-state h3 {
    margin: 0 0 0.6rem;
    color: #555;
  }

  .empty-state p:not(.empty-kicker) {
    max-width: 560px;
    margin: 0 auto 1.25rem;
    line-height: 1.65;
  }

  .empty-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .empty-actions .btn {
    border: 0;
    cursor: pointer;
  }

  .empty-link {
    color: #A0907C;
    font-weight: 700;
  }

  @media (min-width: 900px) {
    .browse-layout {
      grid-template-columns: minmax(220px, 270px) 1fr;
    }
  }
</style>