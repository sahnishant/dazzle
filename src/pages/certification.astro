---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComplianceNote from '../components/ComplianceNote.astro';
import LeadCapturePanel from '../components/LeadCapturePanel.astro';
---
<BaseLayout title="Certification and Hallmark Guidance" description="Dazzle explains laboratory-grown diamond certification, IGI report checks, laser inscription review, and BIS hallmarked metal guidance.">
  <section class="container page-section">
    <h1>Certification and Hallmark Guidance</h1>
    <p class="large-text">For high-consideration laboratory-grown diamond jewellery, trust should be documented before purchase. Ask for stone certification details, metal purity, hallmark information, quote clarity, and delivery terms.</p>
    <ComplianceNote />
    <h2>What to ask before confirming</h2>
    <ul>
      <li>Certificate lab and certificate number, where applicable.</li>
      <li>Stone details: carat weight, cut, colour, clarity, and growth method if stated.</li>
      <li>Laser inscription details where available.</li>
      <li>BIS hallmark and gold purity for the setting.</li>
      <li>Final quote, making charges, delivery timeline, exchange terms, and care guidance.</li>
    </ul>
  </section>
  <section class="container"><LeadCapturePanel title="Send the certificate or product details for review" /></section>
</BaseLayout>
