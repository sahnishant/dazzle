---
// src/pages/privacy-policy.astro
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const privacyPolicy = await getEntry('pages', 'privacy-policy');
if (!privacyPolicy) throw new Error('Missing src/content/pages/privacy-policy.md');
const { Content } = await privacyPolicy.render();
---
<BaseLayout title={privacyPolicy.data.title} description={privacyPolicy.data.description}>
  <section class="container p-4 mt-4 mb-4 privacy-page">
    <h1 class="text-center mb-4">{privacyPolicy.data.title}</h1>
    <div class="privacy-content">
      <Content />
    </div>
    {privacyPolicy.data.updatedAt && (
      <p class="text-small mt-4"><em>Last updated: {privacyPolicy.data.updatedAt.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</em></p>
    )}
  </section>
</BaseLayout>

<style>
  .privacy-page {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 26px rgba(0,0,0,0.06);
  }

  .privacy-content {
    color: #666;
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .text-small {
    font-size: 0.8rem;
    color: #777;
  }

  .privacy-content :global(h2) {
    margin-top: 1.5rem;
  }

  .privacy-content :global(ul) {
    margin-left: 2rem;
    list-style: disc;
    margin-bottom: 1.5rem;
  }

  .privacy-content :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
