---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessContact } from '../data/businessContact.js';
import { jewelryItems } from '../data/jewelry.js';

// Get item ID from URL if redirected from a product page
const urlParams = Astro.url.searchParams;
const inquiredItemId = urlParams.get('item') || '';
const requestedSubject = urlParams.get('subject') || '';
const inquiredItem = jewelryItems.find((item) => item.id === inquiredItemId);
const productPath = inquiredItem ? `/collections/${inquiredItem.category}/${inquiredItem.id}/` : '';
const inquirySubject = inquiredItem
  ? `Inquiry about ${inquiredItem.name}`
  : inquiredItemId
    ? `Inquiry about ${inquiredItemId}`
    : requestedSubject;
const inquiryMessage = inquiredItem
  ? `I am interested in ${inquiredItem.name}.\n\nPrice shown: ${inquiredItem.price}\nProduct link: ${productPath}\n\nPlease share details, availability, and consultation options.`
  : inquiredItemId
    ? `I am interested in the "${inquiredItemId}" piece.`
    : requestedSubject
      ? 'I would like to book a consultation and discuss the next step.'
      : '';
---
<BaseLayout title="Contact Us" description="Get in touch with our diamond experts for inquiries, consultations, or custom designs.">
  <section class="contact-hero container">
    <h1 class="text-center mb-4">Connect With Our Diamond Experts</h1>
    <p class="text-center">Whether you have a question about a specific piece, wish to book a private consultation, or want to discuss a custom design, we're here to help.</p>
  </section>

  <section class="contact-details container mt-4 mb-4">
    <div class="contact-info">
      <h2>Our Contact Information</h2>
      <p><strong>Phone:</strong> <a href={`tel:${businessContact.telHref}`}>{businessContact.displayPhone}</a></p>
      <p><strong>Email:</strong> <a href={`mailto:${businessContact.email}`}>{businessContact.email}</a></p>
      <p><strong>Address:</strong> {businessContact.address}</p>
      <p><strong>Business Hours:</strong> {businessContact.businessHours}</p>
      {businessContact.socials?.length > 0 && (
        <div class="social-links mt-4">
          {businessContact.socials.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer">{social.label}</a>
          ))}
        </div>
      )}
    </div>

    <div class="contact-form-section">
      <h2>Send Us a Message</h2>
      {inquiredItem && (
        <aside class="inquiry-context" aria-label="Selected product inquiry">
          <p class="inquiry-kicker">Selected piece</p>
          <h3>{inquiredItem.name}</h3>
          <p>{inquiredItem.price} · {inquiredItem.material}</p>
          <a href={productPath}>View product details</a>
        </aside>
      )}
      {!inquiredItem && requestedSubject && (
        <aside class="inquiry-context" aria-label="Selected consultation topic">
          <p class="inquiry-kicker">Consultation topic</p>
          <h3>{requestedSubject}</h3>
          <p>We will use this context to guide the conversation.</p>
        </aside>
      )}
      <form name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" action="/thank-you/">
        <input type="hidden" name="form-name" value="contact" />
        {inquiredItem && (
          <>
            <input type="hidden" name="productId" value={inquiredItem.id} />
            <input type="hidden" name="productName" value={inquiredItem.name} />
            <input type="hidden" name="productPath" value={productPath} />
          </>
        )}
        {!inquiredItem && requestedSubject && (
          <input type="hidden" name="consultationTopic" value={requestedSubject} />
        )}
        <p class="hidden">
          <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
        </p>
        
        <div class="form-group">
          <label for="name">Your Name:</label>
          <input type="text" id="name" name="name" required />
        </div>
        
        <div class="form-group">
          <label for="email">Your Email:</label>
          <input type="email" id="email" name="email" required />
        </div>
        
        <div class="form-group">
          <label for="subject">Subject:</label>
          <input type="text" id="subject" name="subject" value={inquirySubject} required />
        </div>
        
        <div class="form-group">
          <label for="message">Message:</label>
          <textarea id="message" name="message" rows="5" required>{inquiryMessage}</textarea>
        </div>
        
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: 3rem 1rem;
    background-color: #f0f0f0;
  }
  .contact-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    background-color: #fff;
    padding: 3rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .contact-info h2, .contact-form-section h2 {
    color: #B0A08C;
    margin-bottom: 1.5rem;
  }
  .contact-info p {
    margin-bottom: 0.8rem;
    font-size: 1.1rem;
  }
  .contact-info a {
    font-weight: bold;
  }
  .social-links a {
    display: inline-block;
    margin-right: 1rem;
    font-size: 1.2rem;
    color: #555;
    transition: color 0.3s ease;
  }
  .social-links a:hover {
    color: #B0A08C;
  }

  .inquiry-context {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border: 1px solid rgba(176, 160, 140, 0.35);
    border-radius: 10px;
    background: #fffaf4;
  }
  .inquiry-kicker {
    margin: 0 0 0.35rem;
    color: #A0907C;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .inquiry-context h3 {
    margin: 0 0 0.35rem;
    color: #555;
    font-size: 1.2rem;
  }
  .inquiry-context p {
    margin: 0 0 0.55rem;
    color: #666;
  }
  .inquiry-context a {
    color: #A0907C;
    font-weight: 700;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
    color: #555;
  }
  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group textarea {
    width: 100%;
    padding: 0.8rem;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 1rem;
    font-family: 'Georgia', serif;
  }
  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #B0A08C;
    box-shadow: 0 0 0 2px rgba(176, 160, 140, 0.2);
  }
  .hidden {
    display: none; /* Netlify honeypot field */
  }

  @media (min-width: 768px) {
    .contact-details {
      grid-template-columns: 1fr 2fr; /* Info on left, form on right */
    }
  }
</style>